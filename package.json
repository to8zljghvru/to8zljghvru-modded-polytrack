{
  "productName": "PolyTrack",
  "author": "Kodub",
  "version": "0.6.0",
  "beta": {
    "version": 7,
    "physicsVersion": 1
  },
  "private": true,
  "main": "electron/main.js",
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0",
    "@electron/packager": "^19.0.1",
    "@eslint/js": "^9.39.1",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/jest": "^30.0.0",
    "@types/pako": "^2.0.4",
    "@types/three": "^0.181.0",
    "@types/webpack-env": "^1.18.8",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "electron": "^39.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-webpack-plugin": "^5.0.2",
    "flag-icons": "^7.5.0",
    "globals": "^16.5.0",
    "html-webpack-plugin": "^5.6.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "js-sha256": "^0.11.1",
    "pako": "^2.1.0",
    "three": "^0.181.0",
    "tslib": "^2.8.1",
    "ws": "^8.18.3"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "dev": "cross-env TARGET=kodub API_URL=http://localhost:8000/ webpack serve --mode=development",
    "build": "cross-env TARGET=kodub API_URL=http://localhost:8000/ webpack --mode=production",
    "prebuild-electron": "cross-env TARGET=electron API_URL=http://localhost:8000/ webpack --mode=development",
    "build-electron": "node electron/build.js",
    "preelectron": "cross-env TARGET=electron API_URL=http://localhost:8000/ webpack --mode=development",
    "electron": "electron ./dist",
    "update-capacitor-icons": "npx @capacitor/assets generate --iconBackgroundColor #28346a --iconBackgroundColorDark #28346a --splashBackgroundColor #28346a --splashBackgroundColorDark #28346a --android --assetPath \"./android/resources\"",
    "android": "cross-env TARGET=capacitor API_URL=http://localhost:8000/ webpack --mode=development && npx cap sync && npx cap run android",
    "build-bullet": "emcmake cmake -Bphysics/bullet/build -Sphysics/bullet -DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DBUILD_SHARED_LIBS=OFF -DBUILD_BULLET2=ON -DBUILD_BULLET3=OFF -DBUILD_MULTITHREADING=OFF -DBUILD_EXTRAS=OFF -DBUILD_UNIT_TESTS=OFF -DUSE_GRAPHICAL_BENCHMARK=OFF -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_FLAGS=\"-O3 -fomit-frame-pointer -flto\" && emmake ninja -C physics/bullet/build",
    "build-physics": "emcc -o lib/polytrack_physics.js -sEXPORT_NAME=PolyTrackPhysics -sMODULARIZE -sENVIRONMENT=worker -sEXPORTED_FUNCTIONS=_malloc,_free -sEXPORTED_RUNTIME_METHODS=ccall,HEAPU8,HEAPF32 -sNO_EXIT_RUNTIME=1 -sALLOW_MEMORY_GROWTH -O3 -flto -Iphysics/bullet/src -Lphysics/bullet/build/src/BulletCollision -Lphysics/bullet/build/src/BulletDynamics -Lphysics/bullet/build/src/LinearMath -lBulletDynamics -lBulletCollision -lLinearMath physics/car_model.cpp physics/obb.cpp physics/physics.cpp physics/track_model.cpp physics/track_part_manager.cpp physics/main.cpp",
    "multiplayer-server": "node server.js",
    "multiplayer-server:smoke": "node multiplayer-server-smoke.js"
  }
}
